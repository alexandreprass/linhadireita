# Banco SQLite (local) ou PostgreSQL (Render)
# Local:
DATABASE_URL="file:./dev.db"
# Render Postgres exemplo:
# DATABASE_URL="postgresql://user:pass@host:5432/linhadireita?sslmode=require"

# API Grok / xAI — https://console.x.ai
XAI_API_KEY=xai-sua-chave
