# Banco: SQLite embutido em prisma/schema.prisma (file:./linhadireita.db)
# Não precisa de DATABASE_URL no Render para SQLite.
# Se migrar para Postgres, ajuste o schema e use:
# DATABASE_URL="postgresql://user:pass@host:5432/linhadireita?sslmode=require"

# API Grok / xAI — https://console.x.ai
XAI_API_KEY=xai-sua-chave
GROK_MODEL=grok-4.5
GROK_IMAGE_MODEL=grok-imagine-image

# Coleta: máximo 2 notícias novas por hora
MAX_REWRITE_PER_CYCLE=2
COLLECT_INTERVAL_MINUTES=60
CRON_SECRET=troque-este-segredo-do-cron

# Admin (login do painel)
ADMIN_USER=admin
ADMIN_PASSWORD=84074070
ADMIN_SESSION_SECRET=troque-por-um-segredo-longo

# Site (SEO / OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
