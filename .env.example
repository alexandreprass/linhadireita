# Coleta
MAX_REWRITE_PER_CYCLE=8
COLLECT_INTERVAL_MINUTES=30
CRON_SECRET=troque-este-segredo-do-cron

# Admin (login do painel)
ADMIN_USER=admin
ADMIN_PASSWORD=84074070
ADMIN_SESSION_SECRET=troque-por-um-segredo-longo

# Site (SEO / OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
