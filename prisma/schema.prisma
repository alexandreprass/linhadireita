// Prisma 5 — SQLite local (simples). No Render use PostgreSQL alterando provider + DATABASE_URL.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  lead            String?
  body            String
  category        String   @default("geral")
  tags            String   @default("[]")
  imageUrl        String?
  sourceId        String?
  sourceName      String?
  originalTitle   String?
  originalLink    String?  @unique
  originalSummary String?
  rewriteModel    String?
  featured        Boolean  @default(false)
  status          String   @default("published")
  isManual        Boolean  @default(false)
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([category])
  @@index([sourceId])
  @@index([featured])
}

model SeenLink {
  link      String   @id
  firstSeen DateTime @default(now())
}

model JobLog {
  id         String    @id @default(cuid())
  kind       String
  status     String
  detail     String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}
